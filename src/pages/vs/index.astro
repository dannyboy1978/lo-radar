---
import Base from "../../layouts/Base.astro";
import { COMPETITORS } from "../../data/competitors.js";
---

<Base
  title="LO Radar vs Competitors — Honest Comparisons"
  description="Side-by-side comparisons of LO Radar against HomeBot, Total Expert, Sales Boomerang, and other mortgage LO tools. Where each one wins, what they share, and how to decide."
>
  <section class="pt-24 pb-12 bg-gradient-to-b from-ink-50/40 to-white">
    <div class="container-xl max-w-5xl">
      <div class="text-xs font-bold uppercase tracking-[0.25em] text-refi-700 mb-4">Comparisons</div>
      <h1 class="font-serif text-5xl md:text-7xl text-ink-900 tracking-tight leading-[1.05] mb-6">
        LO Radar <span class="italic text-gradient-gold">vs the field.</span>
      </h1>
      <p class="text-xl text-ink-600 font-light leading-relaxed max-w-3xl">
        Honest, side-by-side comparisons of LO Radar against the major tools in the mortgage LO retention space. Most of these tools are good at their job. We tell you exactly when to pick them, when to pick us, and when to run both.
      </p>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container-xl max-w-5xl">
      <div class="grid md:grid-cols-2 gap-4">
        {COMPETITORS.map(c => (
          <a href={`/vs/${c.slug}`} class="group bg-ink-50/40 rounded-2xl border border-ink-200 p-6 hover:border-refi-400 hover:shadow-xl transition-all">
            <div class="text-[10px] font-bold uppercase tracking-widest text-ink-400 mb-2">{c.category}</div>
            <h3 class="font-serif text-2xl text-ink-900 mb-2 leading-tight">vs <span class="italic">{c.name}</span></h3>
            <p class="text-sm text-ink-600 mb-4 leading-relaxed line-clamp-3">{c.competitorBlurb}</p>
            <span class="text-xs font-bold uppercase tracking-widest text-ink-700 group-hover:text-refi-700 inline-flex items-center gap-1">
              Read comparison <span class="group-hover:translate-x-0.5 transition-transform">→</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
